# ============================================================
# SPONSOR PORTAL ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit real secrets to git - only commit .env.example
#
# For Raspberry Pi production:
#   cp .env.example .env
#   nano .env  (fill in your values)
#   npm run deploy:pi
#
# For Render cloud deployment:
#   Add these env vars in Render dashboard
# ============================================================

# ============================================================
# GMAIL INTEGRATION (Optional - for email inbox/sending)
# ============================================================
# Your shared team mailbox email
GMAIL_ACCOUNT_EMAIL=atomicf1team@gmail.com

# Get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must match callback URL in Google console
# For Raspberry Pi with Cloudflare Tunnel:
GOOGLE_REDIRECT_URI=https://pi.morrisprints.co.uk/auth/google/callback

# ============================================================
# TEAM BRANDING & PORTAL SETTINGS
# ============================================================
PUBLIC_FUNDRAISING_TARGET=30000
PUBLIC_SITE_PASSWORD=atomic123

# Team/project name shown on auth page
PUBLIC_TEAM_NAME=Atomic
PUBLIC_SEASON_LABEL=2026 Sponsor Programme
PUBLIC_TEAM_SIGNATURE=Partnerships Team | Atomic
PUBLIC_TEAM_WEBSITE=https://example-team-site.com

# Logo path in assets folder
PUBLIC_LOGO_PATH=./assets/atomic-logo-green.jpeg

# Brand colors (hex)
PUBLIC_BRAND_PRIMARY=#32ce32
PUBLIC_BRAND_SECONDARY=#9bff5f
PUBLIC_BRAND_TERTIARY=#d8ffd2
PUBLIC_BRAND_DARK=#07110a

# ============================================================
# SUPABASE DATABASE (Required for multi-user access)
# ============================================================
# Get these from https://supabase.com project settings
#
# These are PUBLIC credentials (safe in frontend):
PUBLIC_SUPABASE_URL=https://frfavsxvfbxtobutgspe.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_Kkg_-BNgbzBGg4hO5tSqjg_VSGn7SEn

# These are for server-side operations:
# The anon key (same as PUBLIC_ version)
SUPABASE_URL=https://frfavsxvfbxtobutgspe.supabase.co
SUPABASE_ANON_KEY=sb_publishable_Kkg_-BNgbzBGg4hO5tSqjg_VSGn7SEn

# Service role key (for RPC calls and admin operations)
# Get this from Supabase project settings > API > Service role key
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# STRIPE PAYMENTS (Optional - not currently used)
# ============================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================================
# ADMIN & API TOKENS (Optional)
# ============================================================
ADMIN_APP_TOKEN=

# ============================================================
# CLOUDFLARE TUNNEL & CACHE PURGE
# ============================================================
# Get from https://dash.cloudflare.com/ > API Tokens
# Create token with permission to purge cache
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ============================================================
# DEPLOYMENT & DEBUGGING
# ============================================================
# Port to run Node server on (default: 3000)
PORT=3000

# For Render only - path to persistent storage
RENDER_DISK_PATH=

# Optional: Gemini AI for company research
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Required for /api/chat sponsorship research assistant
OPENAI_API_KEY=

# ============================================================
# FREE LOCAL AI + SEARCH (Recommended for Raspberry Pi)
# ============================================================
# Uses local Ollama first. Set to:
#  - auto (default): try Ollama, then Gemini if configured
#  - true: Ollama only
#  - false: Gemini only
USE_OLLAMA=auto
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Search provider preference:
#  - duckduckgo (default)
#  - bing
SEARCH_PROVIDER=duckduckgo
